import javax.swing.JOptionPane;

public class Exercicio8 {
    public static void main(String[] args) {
        
        // Solicita o primeiro número
        String entrada1 = JOptionPane.showInputDialog("Digite o primeiro número inteiro:");
        int numero1 = Integer.parseInt(entrada1);
        
        // Solicita o segundo número
        String entrada2 = JOptionPane.showInputDialog("Digite o segundo número inteiro:");
        int numero2 = Integer.parseInt(entrada2);
        
        // Calcula a soma
        int soma = numero1 + numero2;
        
        // Mostra o resultado
        JOptionPane.showMessageDialog(null, "A soma dos dois números é: " + soma);
    }
}
